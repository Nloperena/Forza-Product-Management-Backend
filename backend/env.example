# ============================================================
# FORZA BUILT BACKEND ENVIRONMENT TEMPLATE
# ============================================================
# How to use this file:
# 1) Copy this file to `.env` in the same `backend` directory.
# 2) Replace all placeholder values on the right side of "=".
# 3) Never commit your real `.env` file or real credentials.
#
# Local dev:
# - Use NODE_ENV=development
# - Keep DATABASE_URL empty (SQLite) unless you want local Postgres
#
# Heroku:
# - Set vars with `heroku config:set ...`
# - Heroku injects DATABASE_URL automatically when Postgres add-on exists
# ============================================================


# ============================================================
# 1) CORE SERVER SETTINGS
# ============================================================

# Port the API binds to.
# Local: 5000 is standard.
# Heroku: platform assigns PORT automatically, so do not hardcode there.
PORT=5000

# Environment mode used for logging/security behaviors.
# Allowed: development | production | test
NODE_ENV=development

# Public frontend origin used by CORS and links in outbound emails.
# Local example: http://localhost:3000
# Production example: https://forzabuilt.com
FRONTEND_URL=http://localhost:3000


# ============================================================
# 2) DATABASE SETTINGS
# ============================================================

# SQLite file path used only when DATABASE_URL / POSTGRES_URL are not set.
# Keep this for local fallback.
DB_PATH=./data/products.db

# Optional: force DB auto-init behavior in database service.
# true  -> always attempt initialization
# false -> skip unless explicitly handled
# DB_AUTO_INITIALIZE=false

# PostgreSQL connection string (usually provided by Heroku automatically).
# You normally DO NOT set this locally unless you run local Postgres.
# Example format:
# postgres://username:password@host:5432/database_name
# DATABASE_URL=postgres://...

# Optional alternate Postgres var used by some scripts.
# POSTGRES_URL=postgres://...


# ============================================================
# 3) AUTH / SECURITY SETTINGS
# ============================================================

# JWT signing secret (used for auth tokens where applicable).
# Generate a long random string:
# PowerShell: [Convert]::ToBase64String((1..48 | ForEach-Object {Get-Random -Maximum 256}))
JWT_SECRET=replace-with-a-long-random-secret

# JWT expiration window.
# Examples: 30d, 7d, 12h, 60m
JWT_EXPIRE=30d

# Salt used to hash IP addresses for contact/newsletter anti-abuse logic.
# Must be random and unique per environment.
IP_HASH_SALT=replace-with-random-ip-hash-salt

# Token required for protected admin endpoints.
# Send as header: X-Admin-Token: <value>
ADMIN_TOKEN=replace-with-secure-admin-token


# ============================================================
# 4) API RATE LIMITING / UPLOAD LIMITS
# ============================================================

# Global API limiter window in milliseconds.
# 900000 = 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# Max requests allowed in the above window (global limiter).
RATE_LIMIT_MAX_REQUESTS=100

# Max upload size in bytes.
# 5242880 = 5 MB
MAX_FILE_SIZE=5242880

# Directory for local file uploads.
UPLOAD_DIR=./public/uploads


# ============================================================
# 5) PRODUCT / MEDIA SETTINGS
# ============================================================

# Vercel Blob token used by image routes/scripts.
# Where to get it:
# - Vercel Dashboard -> Storage -> Blob -> your store -> Tokens
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token

# Optional legacy/alternate blob tokens used by scripts.
# VERCEL_BLOB_TOKEN=replace-with-vercel-blob-token
# PRODUCTS_READ_WRITE_TOKEN=replace-with-products-token
# VERCEL_BLOB_BASE_URL=https://<your-store>.public.blob.vercel-storage.com

# Feature toggle for product allowlist logic in product controller.
# true  -> only return allowed products from config list
# false -> return full catalog
ENABLE_PRODUCT_WHITELIST=false


# ============================================================
# 6) POSTMARK EMAIL SETTINGS
# ============================================================

# Postmark server API token for outbound transactional email.
# Where to get it:
# - https://account.postmarkapp.com/servers -> select server -> API Tokens
POSTMARK_API_TOKEN=replace-with-postmark-server-token

# Sender email shown in "From" field for app-sent emails.
# IMPORTANT: must be a verified Sender Signature or approved domain in Postmark.
EMAIL_FROM=noreply@forzabuilt.com

# Internal team address used by legacy internal notification paths.
# (Current contact internal routing is now intended to go through Salesforce Flow.)
TEAM_EMAIL=team@forzabuilt.com

# Enables contact/newsletter email feature gating in readiness checks.
# true  -> /ready requires Postmark configured
# false -> /ready does not fail if Postmark is missing
EMAIL_FEATURES_ENABLED=false


# ============================================================
# 7) SALESFORCE SETTINGS (CONTACT -> LEAD)
# ============================================================
# These values are used by backend/src/services/salesforceService.ts
# to authenticate with OAuth client credentials and create a Lead
# for each contact submission.
#
# Where to get these values:
# - Salesforce Setup -> App Manager -> your Connected App
#   - Consumer Key    -> SALESFORCE_CLIENT_ID
#   - Consumer Secret -> SALESFORCE_CLIENT_SECRET
#
# Required Salesforce app setting:
# - Client Credentials flow must be enabled for this app.
# - App must be configured with a Run As user in Salesforce.

# Connected App Consumer Key
SALESFORCE_CLIENT_ID=replace-with-salesforce-consumer-key

# Connected App Consumer Secret
SALESFORCE_CLIENT_SECRET=replace-with-salesforce-consumer-secret

# Login host:
# - Production org: https://login.salesforce.com
# - Sandbox org:    https://test.salesforce.com
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Optional explicit instance URL fallback used if token response does not
# include "instance_url". Example:
# https://yourdomain.my.salesforce.com
# SALESFORCE_INSTANCE_URL=https://yourdomain.my.salesforce.com

# Optional OAuth scope for token request, if your org requires it.
# SALESFORCE_SCOPE=api

# Legacy username-password keys (not used by current backend auth flow):
# SALESFORCE_USERNAME=...
# SALESFORCE_PASSWORD=...
# SALESFORCE_SECURITY_TOKEN=...

# Optional legacy aliases still supported by code:
# SF_CLIENT_ID=...
# SF_CLIENT_SECRET=...
# SF_INSTANCE_URL=https://login.salesforce.com
# SF_SCOPE=api

